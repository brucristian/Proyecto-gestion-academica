<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER"
            style="-fx-background-color: #0d1b2a; -fx-background: #0d1b2a; -fx-border-color: transparent;"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.unischeduler.ui.pages.profile.AdminProfileController">

    <content>
        <VBox spacing="24" style="-fx-background-color: #0d1b2a;">
            <padding>
                <Insets top="30.0" right="30.0" bottom="30.0" left="30.0"/>
            </padding>

            <VBox spacing="6">
                <Label text="Mi Perfil" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;" />
                <Label text="Gestiona tu información personal y la seguridad de tu cuenta." style="-fx-text-fill: #94a1b2; -fx-font-size: 13px;" />
            </VBox>

            <HBox spacing="30">
                <VBox spacing="18" prefWidth="520" style="-fx-background-color: #152238; -fx-border-color: #415a77; -fx-background-radius: 8; -fx-border-radius: 8; -fx-padding: 24;">
                    <Label text="Información Personal" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: white;" />

                    <StackPane alignment="CENTER" prefHeight="130.0" prefWidth="130.0">
                        <Circle radius="60" style="-fx-fill: #1b263b; -fx-stroke: #94a1b2; -fx-stroke-width: 1;" />
                        <ImageView fx:id="profileImage" fitWidth="120" fitHeight="120" preserveRatio="true"/>
                        <Button text="Cambiar Foto" style="-fx-cursor: hand; -fx-font-size: 11px; -fx-background-color: rgba(0,0,0,0.6); -fx-text-fill: white; -fx-background-radius: 20;" StackPane.alignment="BOTTOM_CENTER">
                            <StackPane.margin><Insets bottom="10.0" /></StackPane.margin>
                        </Button>
                    </StackPane>

                    <VBox spacing="6">
                        <Label text="Nombre completo" style="-fx-text-fill: #94a1b2;" />
                        <TextField fx:id="txtNombre" text="María González" editable="false" style="-fx-background-color: #0d1b2a; -fx-text-fill: #a0a0a0; -fx-border-color: #415a77; -fx-border-radius: 4;" />
                    </VBox>
                    <VBox spacing="6">
                        <Label text="Correo electrónico" style="-fx-text-fill: #94a1b2;" />
                        <TextField fx:id="txtCorreo" text="maria.gonzalez@universidad.edu" editable="false" style="-fx-background-color: #0d1b2a; -fx-text-fill: #a0a0a0; -fx-border-color: #415a77; -fx-border-radius: 4;" />
                    </VBox>
                    <VBox spacing="6">
                        <Label text="Número de teléfono" style="-fx-text-fill: #94a1b2;" />
                        <TextField fx:id="txtTelefono" text="+51 987 654 321" editable="false" style="-fx-background-color: #0d1b2a; -fx-text-fill: #a0a0a0; -fx-border-color: #415a77; -fx-border-radius: 4;" />
                    </VBox>
                    <VBox spacing="6">
                        <Label text="Programa académico" style="-fx-text-fill: #94a1b2;" />
                        <TextField fx:id="txtPrograma" text="Ingeniería de Sistemas" editable="false" style="-fx-background-color: #0d1b2a; -fx-text-fill: #a0a0a0; -fx-border-color: #415a77; -fx-border-radius: 4;" />
                    </VBox>
                    <VBox spacing="6">
                        <Label text="Año de estudio" style="-fx-text-fill: #94a1b2;" />
                        <TextField fx:id="txtAnio" text="3er año" editable="false" style="-fx-background-color: #0d1b2a; -fx-text-fill: #a0a0a0; -fx-border-color: #415a77; -fx-border-radius: 4;" />
                    </VBox>

                    <Button fx:id="btnGuardar" disable="true" text="Guardar cambios" style="-fx-background-color: #2a9d8f; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 4;" maxWidth="Infinity"/>
                </VBox>

                <VBox spacing="18" prefWidth="560" style="-fx-background-color: #152238; -fx-border-color: #415a77; -fx-background-radius: 8; -fx-border-radius: 8; -fx-padding: 24;">
                    <VBox spacing="4">
                        <Label text="Cambiar Contraseña" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: white;" />
                        <Label text="Usa una contraseña segura." style="-fx-text-fill: #94a1b2; -fx-font-size: 12px;" />
                    </VBox>

                    <VBox spacing="6">
                        <Label text="Contraseña actual" style="-fx-text-fill: #94a1b2;" />
                        <PasswordField fx:id="txtActual" style="-fx-background-color: #0d1b2a; -fx-text-fill: white; -fx-border-color: #415a77;" />
                    </VBox>
                    <VBox spacing="6">
                        <Label text="Nueva contraseña" style="-fx-text-fill: #94a1b2;" />
                        <PasswordField fx:id="txtNueva" style="-fx-background-color: #0d1b2a; -fx-text-fill: white; -fx-border-color: #415a77;" />
                        <ProgressBar progress="1.0" maxWidth="Infinity" style="-fx-accent: #2a9d8f;" />
                        <Label text="Fortaleza: Fuerte" style="-fx-text-fill: #2a9d8f; -fx-font-size: 11px; -fx-font-weight: bold;" />
                    </VBox>
                    <VBox spacing="6">
                        <Label text="Confirmar nueva contraseña" style="-fx-text-fill: #94a1b2;" />
                        <PasswordField fx:id="txtConfirmar" style="-fx-background-color: #0d1b2a; -fx-text-fill: white; -fx-border-color: #415a77;" />
                    </VBox>

                    <VBox spacing="8" style="-fx-background-color: #0d1b2a; -fx-padding: 12; -fx-background-radius: 4;">
                        <Label text="Recomendaciones:" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 12px;" />
                        <Label text="• Mínimo 8 caracteres, incluye símbolos." style="-fx-text-fill: #94a1b2; -fx-font-size: 12px;" />
                    </VBox>

                    <Button fx:id="btnActualizarPassword" text="Actualizar contraseña" style="-fx-background-color: #415a77; -fx-text-fill: white; -fx-cursor: hand; -fx-background-radius: 4;" maxWidth="Infinity"/>
                </VBox>
            </HBox>

            <VBox spacing="18" style="-fx-background-color: #152238; -fx-border-color: #415a77; -fx-background-radius: 8; -fx-border-radius: 8; -fx-padding: 24;">
                <Label text="Información de la cuenta" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: white;" />
                <GridPane hgap="20" vgap="16">
                    <columnConstraints><ColumnConstraints percentWidth="50"/><ColumnConstraints percentWidth="50"/></columnConstraints>
                    <Label text="Rol institucional" style="-fx-text-fill: #94a1b2;" GridPane.columnIndex="0" />
                    <Label text="Estudiante" style="-fx-text-fill: white; -fx-font-weight: bold;" GridPane.columnIndex="1" />
                    <Separator style="-fx-opacity: 0.1;" GridPane.columnSpan="2" GridPane.rowIndex="1"/>
                    <Label text="Fecha de registro en plataforma" style="-fx-text-fill: #94a1b2;" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <Label text="15 de febrero de 2022" style="-fx-text-fill: white;" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                </GridPane>
            </VBox>
        </VBox>
    </content>
</ScrollPane>