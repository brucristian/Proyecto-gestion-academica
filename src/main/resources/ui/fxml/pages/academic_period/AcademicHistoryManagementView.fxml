<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="20.0"
      style="-fx-background-color: -fx-bg-dark-primary; -fx-padding: 25;"
      stylesheets="@/css/global.css"
      VBox.vgrow="ALWAYS"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.unischeduler.ui.pages.academic_history.AcademicHistoryManagementController">

    <children>
        <VBox spacing="5.0">
            <children>
                <Label style="-fx-font-weight: bold; -fx-font-size: 22px; -fx-text-fill: white;" text="Gestión de Historial Académico" />
                <Label style="-fx-text-fill: -fx-text-muted; -fx-font-size: 13px;" text="Administre las calificaciones y estados de progreso académico de cualquier estudiante." />
            </children>
        </VBox>

        <Separator style="-fx-opacity: 0.1;" />

        <HBox spacing="25.0" VBox.vgrow="ALWAYS">
            <children>
                <VBox spacing="15.0" HBox.hgrow="ALWAYS">
                    <children>
                        <Label style="-fx-font-weight: bold; -fx-text-fill: white; -fx-font-size: 14px;" text="Búsqueda de Estudiante" />

                        <HBox spacing="10.0">
                            <children>
                                <TextField fx:id="searchStudentField"
                                           promptText="Ingrese el código o ID único del estudiante..."
                                           HBox.hgrow="ALWAYS"
                                           style="-fx-background-color: -fx-bg-dark-secondary; -fx-text-fill: white;" />
                                <Button fx:id="btnSearch"
                                        mnemonicParsing="false"
                                        style="-fx-background-color: -fx-bg-dark-tertiary; -fx-text-fill: white; -fx-cursor: hand; -fx-font-weight: bold;"
                                        text="Buscar" />
                            </children>
                        </HBox>

                        <Label style="-fx-font-weight: bold; -fx-text-fill: white; -fx-font-size: 14px;" text="Asignaturas Registradas" />

                        <TableView fx:id="coursesTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="periodColumn" prefWidth="100.0" text="Periodo" />
                                <TableColumn fx:id="codeColumn" prefWidth="90.0" text="Código" />
                                <TableColumn fx:id="subjectColumn" prefWidth="240.0" text="Asignatura" />
                                <TableColumn fx:id="creditsColumn" prefWidth="80.0" style="-fx-alignment: CENTER;" text="Créditos" />
                                <TableColumn fx:id="gradeColumn" prefWidth="80.0" style="-fx-alignment: CENTER;" text="Nota" />
                                <TableColumn fx:id="statusColumn" prefWidth="110.0" style="-fx-alignment: CENTER;" text="Estado" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </VBox>

                <VBox prefWidth="320.0" spacing="20.0" style="-fx-background-color: -fx-bg-dark-secondary; -fx-padding: 20; -fx-background-radius: 6;">
                    <children>
                        <Label style="-fx-font-weight: bold; -fx-text-fill: white; -fx-font-size: 15px;" text="Información Académica" />

                        <VBox spacing="14.0">
                            <children>
                                <VBox spacing="3.0">
                                    <children>
                                        <Label style="-fx-text-fill: -fx-text-muted; -fx-font-size: 11px;" text="Estudiante Seleccionado:" />
                                        <Label fx:id="studentNameLabel" style="-fx-text-fill: white; -fx-font-weight: bold;" text="Ninguno seleccionado" />
                                    </children>
                                </VBox>
                                <VBox spacing="3.0">
                                    <children>
                                        <Label style="-fx-text-fill: -fx-text-muted; -fx-font-size: 11px;" text="Programa de Estudios:" />
                                        <Label fx:id="programLabel" style="-fx-text-fill: white; -fx-font-weight: bold;" text="---" />
                                    </children>
                                </VBox>
                                <VBox spacing="3.0">
                                    <children>
                                        <Label style="-fx-text-fill: -fx-text-muted; -fx-font-size: 11px;" text="Créditos Aprobados:" />
                                        <Label fx:id="approvedCreditsLabel" style="-fx-text-fill: white; -fx-font-weight: bold;" text="0" />
                                    </children>
                                </VBox>
                                <VBox spacing="3.0">
                                    <children>
                                        <Label style="-fx-text-fill: -fx-text-muted; -fx-font-size: 11px;" text="Promedio Acumulado (PGA):" />
                                        <Label fx:id="gpaLabel" style="-fx-text-fill: -fx-accent-green; -fx-font-weight: bold; -fx-font-size: 22px;" text="0.00" />
                                    </children>
                                </VBox>
                            </children>
                        </VBox>

                        <Separator style="-fx-opacity: 0.1;" />

                        <Label style="-fx-text-fill: -fx-text-muted; -fx-font-size: 11px;"
                               text="Instrucciones: Busque un estudiante. Haga doble clic en la celda 'Nota' para modificar el valor. Presione enter para confirmar y luego guarde."
                               wrapText="true" />
                    </children>
                </VBox>
            </children>
        </HBox>

        <HBox alignment="CENTER_RIGHT" spacing="12.0">
            <children>
                <Button fx:id="btnCancel" mnemonicParsing="false"
                        style="-fx-background-color: transparent; -fx-border-color: -fx-bg-dark-tertiary; -fx-text-fill: -fx-text-muted; -fx-cursor: hand;"
                        text="Limpiar Pantalla" />
                <Button fx:id="btnSave" mnemonicParsing="false"
                        style="-fx-background-color: -fx-accent-green; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"
                        text="Guardar Cambios" />
            </children>
        </HBox>
    </children>
</VBox>
