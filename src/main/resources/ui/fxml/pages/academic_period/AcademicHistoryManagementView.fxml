<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20.0"
      style="-fx-background-color: #0d1b2a;"
      VBox.vgrow="ALWAYS"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.unischeduler.ui.pages.academic_history.AcademicHistoryManagementController">

    <padding>
        <Insets top="25" right="25" bottom="25" left="25"/>
    </padding>

    <!-- HEADER -->
    <VBox spacing="5.0">

        <Label text="Gestión de Historial Académico"
               style="-fx-font-weight: bold; -fx-font-size: 22px; -fx-text-fill: #ffffff;" />

        <Label text="Administre las calificaciones y estados de progreso académico de cualquier estudiante."
               style="-fx-text-fill: #94a1b2; -fx-font-size: 13px;" />

    </VBox>

    <Separator style="-fx-opacity: 0.2; -fx-background-color: #415a77;" />

    <!-- CONTENT -->
    <HBox spacing="25.0" VBox.vgrow="ALWAYS">

        <!-- LEFT -->
        <VBox spacing="15.0" HBox.hgrow="ALWAYS">

            <Label text="Búsqueda de Estudiante"
                   style="-fx-font-weight: bold; -fx-text-fill: #ffffff; -fx-font-size: 14px;" />

            <HBox spacing="10.0">

                <TextField fx:id="searchStudentField"
                           promptText="Ingrese el código o ID único del estudiante..."
                           HBox.hgrow="ALWAYS"
                           style="-fx-background-color: #0d1b2a; -fx-text-fill: #ffffff; -fx-border-color: #415a77;" />

                <Button fx:id="btnSearch"
                        text="Buscar"
                        style="-fx-background-color: #415a77; -fx-text-fill: #ffffff; -fx-font-weight: bold; -fx-cursor: hand;" />

            </HBox>

            <Label text="Asignaturas Registradas"
                   style="-fx-font-weight: bold; -fx-text-fill: #ffffff; -fx-font-size: 14px;" />

            <TableView fx:id="coursesTable"
                       VBox.vgrow="ALWAYS"
                       style="-fx-background-color: #0d1b2a; -fx-border-color: #415a77;">

                <columns>

                    <TableColumn fx:id="periodColumn" prefWidth="100.0" text="Periodo" />
                    <TableColumn fx:id="codeColumn" prefWidth="90.0" text="Código" />
                    <TableColumn fx:id="subjectColumn" prefWidth="240.0" text="Asignatura" />
                    <TableColumn fx:id="creditsColumn" prefWidth="80.0" text="Créditos" style="-fx-alignment: CENTER;" />
                    <TableColumn fx:id="gradeColumn" prefWidth="80.0" text="Nota" style="-fx-alignment: CENTER;" />
                    <TableColumn fx:id="statusColumn" prefWidth="110.0" text="Estado" style="-fx-alignment: CENTER;" />

                </columns>

                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>

            </TableView>

        </VBox>

        <!-- RIGHT PANEL -->
        <VBox prefWidth="320.0"
              spacing="20.0"
              style="-fx-background-color: #152238; -fx-padding: 20; -fx-background-radius: 8;">

            <Label text="Información Académica"
                   style="-fx-font-weight: bold; -fx-text-fill: #ffffff; -fx-font-size: 15px;" />

            <VBox spacing="14.0">

                <VBox spacing="3.0">

                    <Label text="Estudiante Seleccionado:"
                           style="-fx-text-fill: #94a1b2; -fx-font-size: 11px;" />

                    <Label fx:id="studentNameLabel"
                           text="Ninguno seleccionado"
                           style="-fx-text-fill: #ffffff; -fx-font-weight: bold;" />

                </VBox>

                <VBox spacing="3.0">

                    <Label text="Programa de Estudios:"
                           style="-fx-text-fill: #94a1b2; -fx-font-size: 11px;" />

                    <Label fx:id="programLabel"
                           text="---"
                           style="-fx-text-fill: #ffffff; -fx-font-weight: bold;" />

                </VBox>

                <VBox spacing="3.0">

                    <Label text="Créditos Aprobados:"
                           style="-fx-text-fill: #94a1b2; -fx-font-size: 11px;" />

                    <Label fx:id="approvedCreditsLabel"
                           text="0"
                           style="-fx-text-fill: #ffffff; -fx-font-weight: bold;" />

                </VBox>

                <VBox spacing="3.0">

                    <Label text="Promedio Acumulado (PGA):"
                           style="-fx-text-fill: #94a1b2; -fx-font-size: 11px;" />

                    <Label fx:id="gpaLabel"
                           text="0.00"
                           style="-fx-text-fill: #2a9d8f; -fx-font-weight: bold; -fx-font-size: 22px;" />

                </VBox>

            </VBox>

            <Separator style="-fx-opacity: 0.2; -fx-background-color: #415a77;" />

            <Label text="Instrucciones: Busque un estudiante. Haga doble clic en la celda 'Nota' para modificar el valor. Presione enter para confirmar y luego guarde."
                   wrapText="true"
                   style="-fx-text-fill: #94a1b2; -fx-font-size: 11px;" />

        </VBox>

    </HBox>

    <!-- FOOTER -->
    <HBox alignment="CENTER_RIGHT" spacing="12.0">

        <Button fx:id="btnCancel"
                text="Limpiar Pantalla"
                style="-fx-background-color: transparent; -fx-border-color: #415a77; -fx-text-fill: #94a1b2; -fx-cursor: hand;" />

        <Button fx:id="btnSave"
                text="Guardar Cambios"
                style="-fx-background-color: #2a9d8f; -fx-text-fill: #ffffff; -fx-font-weight: bold; -fx-cursor: hand;" />

    </HBox>

</VBox>
