<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="700.0"
      prefWidth="1100.0"
      spacing="20"
      style="-fx-background-color: #0d1b2a;"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.unischeduler.ui.pages.period.PeriodController">

    <padding>
        <Insets top="25" right="25" bottom="25" left="25"/>
    </padding>

    <!-- HEADER -->
    <VBox spacing="5">

        <Label text="Gestión de Períodos Académicos"
               style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #ffffff;" />

        <Label text="Administre los períodos académicos del sistema."
               style="-fx-text-fill: #94a1b2; -fx-font-size: 13px;" />

    </VBox>

    <!-- ACTION BAR -->
    <HBox spacing="10">

        <Button fx:id="newPeriodButton"
                text="+ Nuevo Período"
                onAction="#onNewPeriod"
                style="-fx-background-color: #2a9d8f; -fx-text-fill: #ffffff; -fx-font-weight: bold; -fx-cursor: hand;" />

    </HBox>

    <!-- TABLE -->
    <TableView fx:id="periodTable"
               VBox.vgrow="ALWAYS"
               style="-fx-background-color: #0d1b2a; -fx-border-color: #415a77;">

        <columns>

            <TableColumn fx:id="codeColumn" prefWidth="120" text="Código" />
            <TableColumn fx:id="nameColumn" prefWidth="250" text="Nombre" />
            <TableColumn fx:id="startDateColumn" prefWidth="150" text="Fecha Inicio" style="-fx-alignment: CENTER;" />
            <TableColumn fx:id="endDateColumn" prefWidth="150" text="Fecha Fin" style="-fx-alignment: CENTER;" />
            <TableColumn fx:id="statusColumn" prefWidth="150" text="Estado" style="-fx-alignment: CENTER;" />

        </columns>

        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>

    </TableView>

    <!-- ACTION BUTTONS -->
    <HBox alignment="CENTER_LEFT" spacing="10">

        <Button fx:id="editButton"
                text="Editar"
                onAction="#onEditPeriod"
                style="-fx-background-color: #415a77; -fx-text-fill: #ffffff; -fx-cursor: hand;" />

        <Button fx:id="deleteButton"
                text="Eliminar"
                onAction="#onDeletePeriod"
                style="-fx-background-color: #e76f51; -fx-text-fill: #ffffff; -fx-cursor: hand;" />

        <HBox HBox.hgrow="ALWAYS" alignment="CENTER_RIGHT">

            <Button fx:id="activateButton"
                    text="⚡ Activar Período Seleccionado"
                    onAction="#onActivatePeriod"
                    style="-fx-background-color: #2a9d8f; -fx-text-fill: #ffffff; -fx-font-weight: bold; -fx-cursor: hand;" />

        </HBox>

    </HBox>

    <!-- INFO BANNER -->
    <HBox spacing="10"
          style="-fx-background-color: #152238; -fx-padding: 12; -fx-background-radius: 8; -fx-alignment: CENTER_LEFT;">

        <Label text="ℹ"
               style="-fx-text-fill: #2a9d8f; -fx-font-weight: bold; -fx-font-size: 14px;" />

        <Label text="Sólo puede haber un período académico ACTIVO a la vez para procesar inscripciones."
               style="-fx-text-fill: #94a1b2; -fx-font-size: 13px;" />

    </HBox>

</VBox>