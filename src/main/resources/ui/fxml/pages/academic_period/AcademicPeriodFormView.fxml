<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fitToWidth="true"
            fx:controller="org.unischeduler.ui.pages.period.AcademicPeriodFormController">

    <content>

        <VBox spacing="20">

            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <!-- Título -->

            <VBox spacing="5">

                <Label text="Período Académico"
                       styleClass="page-title"/>

                <Label text="Registro y edición de períodos académicos"
                       styleClass="page-subtitle"/>

            </VBox>

            <Separator/>

            <!-- Formulario -->

            <GridPane hgap="15"
                      vgap="15">

                <columnConstraints>
                    <ColumnConstraints prefWidth="180"/>
                    <ColumnConstraints hgrow="ALWAYS"/>
                </columnConstraints>

                <!-- Código -->

                <Label text="Código"
                       GridPane.rowIndex="0"
                       GridPane.columnIndex="0"/>

                <TextField fx:id="codeField"
                           GridPane.rowIndex="0"
                           GridPane.columnIndex="1"/>

                <!-- Nombre -->

                <Label text="Nombre"
                       GridPane.rowIndex="1"
                       GridPane.columnIndex="0"/>

                <TextField fx:id="nameField"
                           GridPane.rowIndex="1"
                           GridPane.columnIndex="1"/>

                <!-- Fecha Inicio -->

                <Label text="Fecha Inicio"
                       GridPane.rowIndex="2"
                       GridPane.columnIndex="0"/>

                <DatePicker fx:id="startDatePicker"
                            GridPane.rowIndex="2"
                            GridPane.columnIndex="1"/>

                <!-- Fecha Fin -->

                <Label text="Fecha Fin"
                       GridPane.rowIndex="3"
                       GridPane.columnIndex="0"/>

                <DatePicker fx:id="endDatePicker"
                            GridPane.rowIndex="3"
                            GridPane.columnIndex="1"/>

                <!-- Estado -->

                <Label text="Estado"
                       GridPane.rowIndex="4"
                       GridPane.columnIndex="0"/>

                <ComboBox fx:id="statusCombo"
                          GridPane.rowIndex="4"
                          GridPane.columnIndex="1"/>

            </GridPane>

            <Separator/>

            <!-- Botones -->

            <HBox spacing="10"
                  alignment="CENTER_RIGHT">

                <Button fx:id="cancelButton"
                        text="Cancelar"
                        onAction="#onCancel"/>

                <Button fx:id="saveButton"
                        text="Guardar"
                        onAction="#onSave"/>

            </HBox>

        </VBox>

    </content>

</ScrollPane>