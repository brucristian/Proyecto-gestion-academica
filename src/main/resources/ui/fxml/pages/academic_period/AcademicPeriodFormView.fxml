<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true"
            style="-fx-background-color: #0d1b2a;"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.unischeduler.ui.pages.period.AcademicPeriodFormController">

    <content>

        <VBox spacing="20.0"
              style="-fx-background-color: #0d1b2a;">

            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <!-- HEADER -->
            <VBox spacing="5.0">

                <Label text="⏳ Período Académico"
                       style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #ffffff;" />

                <Label text="Registro y edición de períodos académicos del sistema"
                       style="-fx-text-fill: #94a1b2; -fx-font-size: 13px;" />

            </VBox>

            <Separator style="-fx-opacity: 0.2; -fx-background-color: #415a77;" />

            <!-- FORM -->
            <GridPane hgap="15.0" vgap="15.0">

                <columnConstraints>
                    <ColumnConstraints prefWidth="180.0" />
                    <ColumnConstraints hgrow="ALWAYS" />
                </columnConstraints>

                <Label text="Código:"
                       style="-fx-text-fill: #ffffff; -fx-font-weight: bold;"
                       GridPane.columnIndex="0"
                       GridPane.rowIndex="0" />

                <TextField fx:id="codeField"
                           promptText="Ej. 2025-1"
                           style="-fx-background-color: #0d1b2a; -fx-text-fill: #ffffff; -fx-border-color: #415a77;"
                           GridPane.columnIndex="1"
                           GridPane.rowIndex="0" />

                <Label text="Nombre:"
                       style="-fx-text-fill: #ffffff; -fx-font-weight: bold;"
                       GridPane.columnIndex="0"
                       GridPane.rowIndex="1" />

                <TextField fx:id="nameField"
                           promptText="Ej. Primer semestre 2025"
                           style="-fx-background-color: #0d1b2a; -fx-text-fill: #ffffff; -fx-border-color: #415a77;"
                           GridPane.columnIndex="1"
                           GridPane.rowIndex="1" />

                <Label text="Fecha Inicio:"
                       style="-fx-text-fill: #ffffff; -fx-font-weight: bold;"
                       GridPane.columnIndex="0"
                       GridPane.rowIndex="2" />

                <DatePicker fx:id="startDatePicker"
                            promptText="dd/mm/aaaa"
                            style="-fx-background-color: #0d1b2a; -fx-border-color: #415a77;"
                            GridPane.columnIndex="1"
                            GridPane.rowIndex="2" />

                <Label text="Fecha Fin:"
                       style="-fx-text-fill: #ffffff; -fx-font-weight: bold;"
                       GridPane.columnIndex="0"
                       GridPane.rowIndex="3" />

                <DatePicker fx:id="endDatePicker"
                            promptText="dd/mm/aaaa"
                            style="-fx-background-color: #0d1b2a; -fx-border-color: #415a77;"
                            GridPane.columnIndex="1"
                            GridPane.rowIndex="3" />

                <Label text="Estado:"
                       style="-fx-text-fill: #ffffff; -fx-font-weight: bold;"
                       GridPane.columnIndex="0"
                       GridPane.rowIndex="4" />

                <ComboBox fx:id="statusCombo"
                          promptText="Seleccionar estado"
                          style="-fx-background-color: #0d1b2a; -fx-text-fill: #ffffff; -fx-border-color: #415a77;"
                          GridPane.columnIndex="1"
                          GridPane.rowIndex="4" />

            </GridPane>

            <Separator style="-fx-opacity: 0.2; -fx-background-color: #415a77;" />

            <!-- ACTIONS -->
            <HBox alignment="CENTER_RIGHT" spacing="15.0">

                <Button fx:id="cancelButton"
                        text="Cancelar"
                        onAction="#onCancel"
                        style="-fx-background-color: transparent; -fx-border-color: #415a77; -fx-text-fill: #94a1b2; -fx-cursor: hand;" />

                <Button fx:id="saveButton"
                        text="Guardar Período"
                        onAction="#onSave"
                        style="-fx-background-color: #2a9d8f; -fx-text-fill: #ffffff; -fx-font-weight: bold; -fx-cursor: hand;" />

            </HBox>

        </VBox>

    </content>

</ScrollPane>