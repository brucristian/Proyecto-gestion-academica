<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.unischeduler.ui.pages.academic_history.AcademicHistoryController"
      spacing="20" style="-fx-padding: 30; -fx-background-color: #0d1b2a;">

    <GridPane hgap="20" style="-fx-background-color: #152238; -fx-padding: 20; -fx-background-radius: 10; -fx-border-color: #415a77; -fx-border-radius: 10;">
        <columnConstraints>
            <ColumnConstraints percentWidth="25" hgrow="ALWAYS"/>
            <ColumnConstraints percentWidth="25" hgrow="ALWAYS"/>
            <ColumnConstraints percentWidth="25" hgrow="ALWAYS"/>
            <ColumnConstraints percentWidth="25" hgrow="ALWAYS"/>
        </columnConstraints>

        <VBox GridPane.columnIndex="0" spacing="5">
            <Label text="Estudiante" style="-fx-text-fill: #94a1b2; -fx-font-size: 11px; -fx-text-transform: uppercase;"/>
            <Label fx:id="studentNameLabel" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px;"/>
        </VBox>

        <VBox GridPane.columnIndex="1" spacing="5">
            <Label text="Programa" style="-fx-text-fill: #94a1b2; -fx-font-size: 11px; -fx-text-transform: uppercase;"/>
            <Label fx:id="programLabel" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px;"/>
        </VBox>

        <VBox GridPane.columnIndex="2" spacing="5">
            <Label text="Créditos Aprobados" style="-fx-text-fill: #94a1b2; -fx-font-size: 11px; -fx-text-transform: uppercase;"/>
            <Label fx:id="approvedCreditsLabel" style="-fx-text-fill: #2a9d8f; -fx-font-weight: bold; -fx-font-size: 14px;"/>
        </VBox>

        <VBox GridPane.columnIndex="3" spacing="5">
            <Label text="Promedio Acumulado" style="-fx-text-fill: #94a1b2; -fx-font-size: 11px; -fx-text-transform: uppercase;"/>
            <Label fx:id="gpaLabel" style="-fx-text-fill: #2a9d8f; -fx-font-weight: bold; -fx-font-size: 14px;"/>
        </VBox>
    </GridPane>

    <Label text="Asignaturas Cursadas" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16px;"/>

    <TableView fx:id="coursesTable" VBox.vgrow="ALWAYS"
               style="-fx-background-color: #152238; -fx-border-color: #415a77; -fx-border-radius: 6; -fx-table-cell-border-color: #2b3a4a;">
        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
        <columns>
            <TableColumn fx:id="codeColumn" text="Código" prefWidth="100"/>
            <TableColumn fx:id="subjectColumn" text="Asignatura" prefWidth="300"/>
            <TableColumn fx:id="creditsColumn" text="Créditos" prefWidth="100"/>
            <TableColumn fx:id="periodColumn" text="Periodo" prefWidth="120"/>
            <TableColumn fx:id="gradeColumn" text="Nota" prefWidth="100"/>
            <TableColumn fx:id="statusColumn" text="Estado" prefWidth="150"/>
        </columns>
    </TableView>

    <Label text="Nota: Historia académica de solo lectura."
           style="-fx-text-fill: #778da9; -fx-font-style: italic; -fx-font-size: 12px;"/>

</VBox>