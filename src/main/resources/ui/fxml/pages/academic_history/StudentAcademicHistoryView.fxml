<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="700.0" prefWidth="1100.0" style="-fx-background-color: -fx-bg-dark-primary;" stylesheets="@/css/global.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    <children>

        <HBox alignment="CENTER_LEFT" prefHeight="50.0" spacing="20.0" style="-fx-background-color: -fx-bg-dark-secondary; -fx-padding: 0 20; -fx-border-color: transparent transparent -fx-bg-dark-tertiary transparent;">
            <children>
                <Label style="-fx-background-color: transparent; -fx-text-fill: white;" text="☰" />
                <Label style="-fx-font-weight: bold; -fx-font-size: 16px;" text="Historial Académico" HBox.hgrow="ALWAYS" />
                <HBox alignment="CENTER_RIGHT" spacing="10.0" HBox.hgrow="ALWAYS">
                    <children>
                        <Label style="-fx-text-fill: -fx-text-muted;" text="👤 20211234" />
                        <Label style="-fx-font-weight: bold;" text="Estudiante" />
                    </children>
                </HBox>
            </children>
        </HBox>

        <VBox spacing="20.0" style="-fx-padding: 20;" VBox.vgrow="ALWAYS">
            <children>

                <HBox spacing="15.0" stylesheets="@/css/history.css">
                    <children>
                        <VBox styleClass="summary-card" HBox.hgrow="ALWAYS">
                            <children>
                                <Label styleClass="summary-card-title" text="Estudiante" />
                                <Label styleClass="summary-card-value" text="Juan Pérez" />
                            </children>
                        </VBox>

                        <VBox styleClass="summary-card" HBox.hgrow="ALWAYS">
                            <children>
                                <Label styleClass="summary-card-title" text="Programa" />
                                <Label styleClass="summary-card-value" text="Ingeniería de Sistemas" />
                            </children>
                        </VBox>

                        <VBox styleClass="summary-card" HBox.hgrow="ALWAYS">
                            <children>
                                <Label styleClass="summary-card-title" text="Créditos Aprobados" />
                                <Label styleClass="summary-card-value" text="128" />
                            </children>
                        </VBox>

                        <VBox styleClass="summary-card" HBox.hgrow="ALWAYS">
                            <children>
                                <Label styleClass="summary-card-title" text="Promedio Acumulado" />
                                <Label styleClass="summary-card-value" text="4.25" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <Label style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-padding: 10 0 0 0;" text="Asignaturas Cursadas" />

                <TableView VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn prefWidth="90.0" text="Código" />
                        <TableColumn prefWidth="350.0" text="Asignatura" />
                        <TableColumn prefWidth="80.0" style="-fx-alignment: CENTER;" text="Créditos" />
                        <TableColumn prefWidth="100.0" style="-fx-alignment: CENTER;" text="Periodo" />
                        <TableColumn prefWidth="80.0" style="-fx-alignment: CENTER;" text="Nota" />
                        <TableColumn prefWidth="120.0" style="-fx-alignment: CENTER;" text="Estado" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>

                <Label style="-fx-text-fill: -fx-text-muted; -fx-font-style: italic;" text="Nota: Historia académica de solo lectura." />

            </children>
        </VBox>
    </children>
</VBox>