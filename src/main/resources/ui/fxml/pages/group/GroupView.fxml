<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.unischeduler.ui.pages.group.GroupController">

    <center>
        <VBox spacing="15.0"
              BorderPane.alignment="CENTER">

            <padding>
                <Insets top="15" right="15" bottom="15" left="15"/>
            </padding>

            <!-- ========================== -->
            <!-- TOP SECTION -->
            <!-- ========================== -->

            <HBox spacing="15">

                <!-- LEFT PANEL -->
                <VBox spacing="10"
                      prefWidth="400">

                    <Label text="Información del Grupo"
                           style="-fx-font-size: 14px; -fx-font-weight: bold;"/>

                    <GridPane hgap="10"
                              vgap="10">

                        <columnConstraints>
                            <ColumnConstraints prefWidth="100"/>
                            <ColumnConstraints hgrow="ALWAYS"/>
                        </columnConstraints>

                        <Label text="Asignatura:"
                               GridPane.rowIndex="0"
                               GridPane.columnIndex="0"/>

                        <ComboBox fx:id="courseComboBox"
                                  prefWidth="250"
                                  GridPane.rowIndex="0"
                                  GridPane.columnIndex="1"/>

                        <Label text="Grupo:"
                               GridPane.rowIndex="1"
                               GridPane.columnIndex="0"/>

                        <TextField fx:id="groupCodeField"
                                   GridPane.rowIndex="1"
                                   GridPane.columnIndex="1"/>

                        <Label text="Docente:"
                               GridPane.rowIndex="2"
                               GridPane.columnIndex="0"/>

                        <ComboBox fx:id="teacherComboBox"
                                  GridPane.rowIndex="2"
                                  GridPane.columnIndex="1"/>

                        <Label text="Capacidad:"
                               GridPane.rowIndex="3"
                               GridPane.columnIndex="0"/>

                        <Spinner fx:id="capacitySpinner"
                                 editable="true"
                                 GridPane.rowIndex="3"
                                 GridPane.columnIndex="1"/>

                        <Label text="Cupos Disponibles:"
                               GridPane.rowIndex="4"
                               GridPane.columnIndex="0"/>

                        <Spinner fx:id="availableSlotsSpinner"
                                 editable="true"
                                 GridPane.rowIndex="4"
                                 GridPane.columnIndex="1"/>

                    </GridPane>

                    <HBox spacing="10">

                        <Button fx:id="newGroupButton"
                                text="+ Nuevo Grupo"
                                onAction="#onNewGroup"/>

                        <Button fx:id="saveGroupButton"
                                text="Guardar"
                                onAction="#onSaveGroup"/>

                        <Button fx:id="deleteGroupButton"
                                text="Eliminar"
                                onAction="#onDeleteGroup"/>

                    </HBox>

                </VBox>

                <!-- RIGHT PANEL -->
                <VBox spacing="10"
                      HBox.hgrow="ALWAYS">

                    <Label text="Horarios del Grupo"
                           style="-fx-font-size: 14px; -fx-font-weight: bold;"/>

                    <TableView fx:id="scheduleTable"
                               VBox.vgrow="ALWAYS">

                        <columns>

                            <TableColumn fx:id="dayColumn"
                                         text="Día"
                                         prefWidth="150"/>

                            <TableColumn fx:id="startTimeColumn"
                                         text="Hora Inicio"
                                         prefWidth="120"/>

                            <TableColumn fx:id="endTimeColumn"
                                         text="Hora Fin"
                                         prefWidth="120"/>

                            <TableColumn fx:id="roomColumn"
                                         text="Salón"
                                         prefWidth="120"/>

                        </columns>

                    </TableView>

                    <HBox spacing="10">

                        <Button fx:id="addScheduleButton"
                                text="+ Agregar Horario"
                                onAction="#onAddSchedule"/>

                        <Button fx:id="removeScheduleButton"
                                text="Eliminar"
                                onAction="#onRemoveSchedule"/>

                    </HBox>

                </VBox>

            </HBox>

            <!-- ========================== -->
            <!-- GROUPS LIST -->
            <!-- ========================== -->

            <VBox spacing="10"
                  VBox.vgrow="ALWAYS">

                <Label text="Grupos Existentes"
                       style="-fx-font-size: 14px; -fx-font-weight: bold;"/>

                <TextField fx:id="searchField"
                           promptText="Buscar grupo..."/>

                <TableView fx:id="groupsTable"
                           VBox.vgrow="ALWAYS">

                    <columns>

                        <TableColumn fx:id="courseColumn"
                                     text="Asignatura"
                                     prefWidth="250"/>

                        <TableColumn fx:id="groupColumn"
                                     text="Grupo"
                                     prefWidth="100"/>

                        <TableColumn fx:id="teacherColumn"
                                     text="Docente"
                                     prefWidth="220"/>

                        <TableColumn fx:id="capacityColumn"
                                     text="Capacidad"
                                     prefWidth="120"/>

                        <TableColumn fx:id="availableColumn"
                                     text="Cupos Disp."
                                     prefWidth="120"/>

                    </columns>

                </TableView>

            </VBox>

        </VBox>
    </center>

</BorderPane>