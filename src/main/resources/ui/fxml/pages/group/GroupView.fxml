<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<BorderPane style="-fx-background-color: -fx-bg-dark-primary;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1">

    <center>
        <VBox spacing="15.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="15" right="15" bottom="15" left="15"/>
            </padding>

            <HBox spacing="15">

                <VBox spacing="10" prefWidth="400">
                    <children>
                        <Label text="Información del Grupo"
                               style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: white;"/>

                        <GridPane hgap="10" vgap="10">
                            <columnConstraints>
                                <ColumnConstraints prefWidth="120"/>
                                <ColumnConstraints hgrow="ALWAYS"/>
                            </columnConstraints>
                            <rowConstraints>
                                <RowConstraints minHeight="30.0"/>
                                <RowConstraints minHeight="30.0"/>
                                <RowConstraints minHeight="30.0"/>
                                <RowConstraints minHeight="30.0"/>
                                <RowConstraints minHeight="30.0"/>
                            </rowConstraints>
                            <children>
                                <Label text="Asignatura:" style="-fx-text-fill: -fx-text-muted;" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                                <ComboBox fx:id="courseComboBox" prefWidth="250" style="-fx-cursor: hand;" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                                <Label text="Grupo:" style="-fx-text-fill: -fx-text-muted;" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                                <TextField fx:id="groupCodeField" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                                <Label text="Docente:" style="-fx-text-fill: -fx-text-muted;" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                                <ComboBox fx:id="teacherComboBox" prefWidth="250" style="-fx-cursor: hand;" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                                <Label text="Capacidad:" style="-fx-text-fill: -fx-text-muted;" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                                <Spinner fx:id="capacitySpinner" editable="true" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                                <Label text="Cupos Disponibles:" style="-fx-text-fill: -fx-text-muted;" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                                <Spinner fx:id="availableSlotsSpinner" editable="true" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
                            </children>
                        </GridPane>

                        <HBox spacing="10" style="-fx-padding: 10 0 0 0;">
                            <children>
                                <Button fx:id="newGroupButton" text="+ Nuevo Grupo" styleClass="button" style="-fx-cursor: hand; -fx-background-color: -fx-bg-dark-tertiary; -fx-text-fill: white;"/>
                                <Button fx:id="saveGroupButton" text="Guardar" styleClass="button" style="-fx-cursor: hand; -fx-background-color: -fx-accent-green; -fx-text-fill: white; -fx-font-weight: bold;"/>
                                <Button fx:id="deleteGroupButton" text="Eliminar" styleClass="button" style="-fx-cursor: hand; -fx-background-color: #EF4444; -fx-text-fill: white;"/>
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <VBox spacing="10" HBox.hgrow="ALWAYS">
                    <children>
                        <Label text="Horarios del Grupo"
                               style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: white;"/>

                        <TableView fx:id="scheduleTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="dayColumn" text="Día" prefWidth="150"/>
                                <TableColumn fx:id="startTimeColumn" text="Hora Inicio" prefWidth="120"/>
                                <TableColumn fx:id="endTimeColumn" text="Hora Fin" prefWidth="120"/>
                                <TableColumn fx:id="roomColumn" text="Salón" prefWidth="120"/>
                            </columns>
                        </TableView>

                        <HBox spacing="10">
                            <children>
                                <Button fx:id="addScheduleButton" text="+ Agregar Horario" styleClass="button" style="-fx-cursor: hand; -fx-background-color: -fx-bg-dark-tertiary; -fx-text-fill: white;"/>
                                <Button fx:id="removeScheduleButton" text="Eliminar Horario" styleClass="button" style="-fx-cursor: hand; -fx-background-color: transparent; -fx-border-color: -fx-bg-dark-tertiary; -fx-text-fill: -fx-text-muted;"/>
                            </children>
                        </HBox>
                    </children>
                </VBox>

            </HBox>

            <VBox spacing="10" VBox.vgrow="ALWAYS">
                <children>
                    <Label text="Grupos Existentes"
                           style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: white;"/>

                    <TextField fx:id="searchField" promptText="Buscar grupo por asignatura, código o docente..."/>

                    <TableView fx:id="groupsTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="courseColumn" text="Asignatura" prefWidth="250"/>
                            <TableColumn fx:id="groupColumn" text="Grupo" prefWidth="100" style="-fx-alignment: CENTER;"/>
                            <TableColumn fx:id="teacherColumn" text="Docente" prefWidth="220"/>
                            <TableColumn fx:id="capacityColumn" text="Capacidad" prefWidth="120" style="-fx-alignment: CENTER;"/>
                            <TableColumn fx:id="availableColumn" text="Cupos Disp." prefWidth="120" style="-fx-alignment: CENTER;"/>
                        </columns>
                    </TableView>
                </children>
            </VBox>

        </VBox>
    </center>

</BorderPane>