<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane style="-fx-background-color: #0d1b2a;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.unischeduler.ui.pages.group.GroupController">

    <center>
        <VBox spacing="20.0">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <HBox spacing="20">
                <VBox spacing="15" prefWidth="400" style="-fx-background-color: #152238; -fx-padding: 20; -fx-background-radius: 8; -fx-border-color: #415a77; -fx-border-radius: 8;">
                    <Label text="Información del Grupo" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;"/>

                    <GridPane hgap="10" vgap="15">
                        <columnConstraints>
                            <ColumnConstraints prefWidth="120"/>
                            <ColumnConstraints hgrow="ALWAYS"/>
                        </columnConstraints>

                        <Label text="Asignatura:" style="-fx-text-fill: #94a1b2;" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <ComboBox fx:id="courseComboBox" maxWidth="Infinity" style="-fx-background-color: #0d1b2a; -fx-text-fill: white; -fx-border-color: #415a77;" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                        <Label text="Grupo:" style="-fx-text-fill: #94a1b2;" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <TextField fx:id="groupCodeField" style="-fx-background-color: #0d1b2a; -fx-text-fill: white; -fx-border-color: #415a77;" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                        <Label text="Docente:" style="-fx-text-fill: #94a1b2;" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                        <ComboBox fx:id="teacherComboBox" maxWidth="Infinity" style="-fx-background-color: #0d1b2a; -fx-text-fill: white; -fx-border-color: #415a77;" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                        <Label text="Capacidad:" style="-fx-text-fill: #94a1b2;" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                        <Spinner fx:id="capacitySpinner" editable="true" style="-fx-background-color: #0d1b2a;" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                        <Label text="Cupos Disp.:" style="-fx-text-fill: #94a1b2;" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                        <Spinner fx:id="availableSlotsSpinner" editable="true" style="-fx-background-color: #0d1b2a;" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
                    </GridPane>

                    <HBox spacing="10" style="-fx-padding: 10 0 0 0;">
                        <Button fx:id="newGroupButton" text="+ Nuevo" style="-fx-background-color: #415a77; -fx-text-fill: white; -fx-cursor: hand;"/>
                        <Button fx:id="saveGroupButton" text="Guardar" style="-fx-background-color: #2a9d8f; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
                        <Button fx:id="deleteGroupButton" text="Eliminar" style="-fx-background-color: #e76f51; -fx-text-fill: white; -fx-cursor: hand;"/>
                    </HBox>
                </VBox>

                <VBox spacing="10" HBox.hgrow="ALWAYS" style="-fx-background-color: #152238; -fx-padding: 20; -fx-background-radius: 8; -fx-border-color: #415a77; -fx-border-radius: 8;">
                    <Label text="Horarios del Grupo" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    <TableView fx:id="scheduleTable" VBox.vgrow="ALWAYS" style="-fx-background-color: #0d1b2a; -fx-table-cell-border-color: #2b3a4a;">
                        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                        <columns>
                            <TableColumn fx:id="dayColumn" text="Día"/>
                            <TableColumn fx:id="startTimeColumn" text="Hora Inicio"/>
                            <TableColumn fx:id="endTimeColumn" text="Hora Fin"/>
                            <TableColumn fx:id="roomColumn" text="Salón"/>
                        </columns>
                    </TableView>
                    <HBox spacing="10">
                        <Button fx:id="addScheduleButton" text="+ Agregar Horario" style="-fx-background-color: #415a77; -fx-text-fill: white; -fx-cursor: hand;"/>
                        <Button fx:id="removeScheduleButton" text="Eliminar Horario" style="-fx-background-color: transparent; -fx-border-color: #415a77; -fx-text-fill: #94a1b2; -fx-cursor: hand;"/>
                    </HBox>
                </VBox>
            </HBox>

            <VBox spacing="10" VBox.vgrow="ALWAYS" style="-fx-background-color: #152238; -fx-padding: 20; -fx-background-radius: 8; -fx-border-color: #415a77; -fx-border-radius: 8;">
                <Label text="Grupos Existentes" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <TextField fx:id="searchField" promptText="Buscar grupo..." style="-fx-background-color: #0d1b2a; -fx-text-fill: white; -fx-border-color: #415a77;"/>
                <TableView fx:id="groupsTable" VBox.vgrow="ALWAYS" style="-fx-background-color: #0d1b2a; -fx-table-cell-border-color: #2b3a4a;">
                    <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                    <columns>
                        <TableColumn fx:id="courseColumn" text="Asignatura"/>
                        <TableColumn fx:id="groupColumn" text="Grupo"/>
                        <TableColumn fx:id="teacherColumn" text="Docente"/>
                        <TableColumn fx:id="capacityColumn" text="Capacidad"/>
                        <TableColumn fx:id="availableColumn" text="Cupos Disp."/>
                    </columns>
                </TableView>
            </VBox>
        </VBox>
    </center>
</BorderPane>