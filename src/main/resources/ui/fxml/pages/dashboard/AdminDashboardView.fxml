<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<BorderPane prefHeight="700.0" prefWidth="1100.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">

    <stylesheets>
        <URL value="@/css/dasboard.css" />
    </stylesheets>

    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="50.0" spacing="20.0" style="-fx-background-color: #0b132b; -fx-padding: 0 20; -fx-border-color: transparent transparent #415a77 transparent;">
            <children>
                <Button text="☰" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand;" />
                <Label text="Admin Workspace" style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #415a77;" />
                <HBox alignment="CENTER_RIGHT" spacing="10.0" HBox.hgrow="ALWAYS">
                    <children>
                        <Label text=" Admin" style="-fx-text-fill: #94a1b2;" />
                        <Label text="Sistema" style="-fx-font-weight: bold; -fx-text-fill: white;" />
                    </children>
                </HBox>
            </children>
        </HBox>
    </top>

    <center>
        <VBox spacing="25.0" style="-fx-background-color: #0d1b2a; -fx-padding: 30;" BorderPane.alignment="CENTER">
            <children>
                <VBox spacing="5.0">
                    <children>
                        <Label text="Resumen del Sistema" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;" />
                        <Label text="Vista general del estado actual de la plataforma." style="-fx-text-fill: #94a1b2;" />
                    </children>
                </VBox>

                <HBox spacing="20.0">
                    <children>
                        <HBox spacing="15.0" HBox.hgrow="ALWAYS" style="-fx-background-color: #152238; -fx-padding: 20; -fx-background-radius: 12; -fx-border-color: #2b3a4a; -fx-border-radius: 12;">
                            <children>
                                <Label text="👥" style="-fx-font-size: 32; -fx-text-fill: #415a77;" />
                                <VBox alignment="CENTER_LEFT">
                                    <Label text="Total Estudiantes" style="-fx-text-fill: #94a1b2; -fx-font-size: 12;" />
                                    <Label text="1,245" style="-fx-text-fill: white; -fx-font-size: 22; -fx-font-weight: bold;" />
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>
</BorderPane>