<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="25.0" VBox.vgrow="ALWAYS"
      style="-fx-background-color: #0d1b2a; -fx-padding: 30;"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">

    <children>
        <VBox spacing="5.0">
            <children>
                <Label fx:id="lblWelcomeMessage" text="¡Bienvenido, Juan Pérez!"
                       style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #2a9d8f;" />
                <Label text="Aquí tienes un resumen de tu estado académico actual."
                       style="-fx-text-fill: #94a1b2; -fx-font-size: 14px;" />
            </children>
        </VBox>

        <HBox spacing="20.0">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="15.0" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: #152238; -fx-padding: 20; -fx-background-radius: 10; -fx-border-color: rgba(255,255,255,0.05); -fx-border-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 10, 0, 0, 4);">
                    <children>
                        <VBox alignment="CENTER_LEFT">
                            <Label text="Programa Académico" style="-fx-text-fill: #778da9; -fx-font-size: 11px; -fx-text-transform: uppercase;" />
                            <Label fx:id="lblCareerName" text="Ingeniería de Sistemas" style="-fx-font-weight: bold; -fx-text-fill: #e0e1dd; -fx-font-size: 16px;" />
                        </VBox>
                    </children>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="15.0" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: #152238; -fx-padding: 20; -fx-background-radius: 10; -fx-border-color: rgba(255,255,255,0.05); -fx-border-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 10, 0, 0, 4);">
                    <children>
                        <VBox alignment="CENTER_LEFT">
                            <Label text="Periodo Activo" style="-fx-text-fill: #778da9; -fx-font-size: 11px; -fx-text-transform: uppercase;" />
                            <Label fx:id="lblAcademicPeriod" text="2026-1" style="-fx-font-weight: bold; -fx-text-fill: #e0e1dd; -fx-font-size: 16px;" />
                        </VBox>
                    </children>
                </HBox>
            </children>
        </HBox>

        <VBox spacing="12.0">
            <children>
                <Label text="Accesos Rápidos" style="-fx-font-weight: bold; -fx-text-fill: white; -fx-font-size: 16px;" />
                <GridPane hgap="15.0" vgap="15.0">
                    <columnConstraints>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="25" />
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="25" />
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="25" />
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="25" />
                    </columnConstraints>
                    <children>
                        <Button fx:id="btnQuickEnroll" text="Ingresar al Espacio Académico" GridPane.columnIndex="0" maxWidth="Infinity" maxHeight="Infinity"
                                style="-fx-cursor: hand; -fx-font-weight: bold; -fx-background-color: linear-gradient(to bottom, #1b263b, #152238); -fx-text-fill: white; -fx-border-color: #415a77; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 5, 0, 0, 2);" />
                        <Button fx:id="btnQuickHistory" text="Consultar Historial Académico" GridPane.columnIndex="1" maxWidth="Infinity" maxHeight="Infinity"
                                style="-fx-cursor: hand; -fx-font-weight: bold; -fx-background-color: linear-gradient(to bottom, #1b263b, #152238); -fx-text-fill: white; -fx-border-color: #415a77; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 5, 0, 0, 2);" />
                        <Button fx:id="btnQuickSchedule" text="Ver Horario Provisional" GridPane.columnIndex="2" maxWidth="Infinity" maxHeight="Infinity"
                                style="-fx-cursor: hand; -fx-font-weight: bold; -fx-background-color: linear-gradient(to bottom, #1b263b, #152238); -fx-text-fill: white; -fx-border-color: #415a77; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 5, 0, 0, 2);" />
                        <Button fx:id="btnQuickNotifications" text="Notificaciones" GridPane.columnIndex="3" maxWidth="Infinity" maxHeight="Infinity"
                                style="-fx-cursor: hand; -fx-font-weight: bold; -fx-background-color: linear-gradient(to bottom, #1b263b, #152238); -fx-text-fill: white; -fx-border-color: #415a77; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 5, 0, 0, 2);" />
                    </children>
                </GridPane>
            </children>
        </VBox>

        <VBox spacing="10.0" VBox.vgrow="ALWAYS"
              style="-fx-background-color: #152238; -fx-padding: 20; -fx-background-radius: 10; -fx-border-color: rgba(255,255,255,0.05); -fx-border-radius: 10;">
            <children>
                <HBox alignment="CENTER_LEFT">
                    <Label text="Avisos de la Institución" style="-fx-font-weight: bold; -fx-text-fill: white; -fx-font-size: 15px;" />
                    <HBox alignment="CENTER_RIGHT" HBox.hgrow="ALWAYS">
                        <Hyperlink fx:id="lnkViewAllNotices" text="Ver todos los anuncios" style="-fx-text-fill: #2a9d8f; -fx-underline: true;" />
                    </HBox>
                </HBox>
                <Label fx:id="lblNoticeContent" text="• Las evaluaciones correspondientes al primer corte del ciclo académico 2026-1 se encontrarán disponibles para consulta en los canales oficiales." wrapText="true"
                       style="-fx-text-fill: #e2e8f0; -fx-font-size: 13px;" />
            </children>
        </VBox>
    </children>
</VBox>