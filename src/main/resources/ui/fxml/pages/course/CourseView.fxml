<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.unischeduler.ui.pages.course.CourseController"
            prefHeight="750.0"
            prefWidth="1300.0">

    <center>

        <VBox spacing="15">

            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <!-- HEADER -->

            <VBox spacing="5">

                <Label text="Gestión de Catálogo Académico"
                       styleClass="page-title"/>

                <Label text="Administración de cursos y prerrequisitos"
                       styleClass="page-subtitle"/>

            </VBox>

            <!-- MAIN CONTENT -->

            <SplitPane dividerPositions="0.48">

                <!-- ===================================================== -->
                <!-- PANEL IZQUIERDO                                       -->
                <!-- ===================================================== -->

                <AnchorPane>

                    <VBox spacing="12"
                          AnchorPane.topAnchor="0.0"
                          AnchorPane.bottomAnchor="0.0"
                          AnchorPane.leftAnchor="0.0"
                          AnchorPane.rightAnchor="0.0">

                        <Label text="Lista de Asignaturas"
                               styleClass="section-title"/>

                        <!-- SEARCH -->

                        <TextField fx:id="searchField"
                                   promptText="Buscar por código o nombre..."/>

                        <!-- TABLE -->

                        <TableView fx:id="coursesTable"
                                   VBox.vgrow="ALWAYS">

                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                            </columnResizePolicy>

                            <columns>

                                <TableColumn fx:id="codeColumn"
                                             text="Código"
                                             prefWidth="120"/>

                                <TableColumn fx:id="nameColumn"
                                             text="Asignatura"
                                             prefWidth="250"/>

                                <TableColumn fx:id="creditsColumn"
                                             text="Créditos"
                                             prefWidth="90"/>

                            </columns>

                        </TableView>

                        <!-- ACTIONS -->

                        <HBox spacing="10">

                            <Button fx:id="newCourseButton"
                                    text="+ Nuevo"
                                    styleClass="success-button"
                                    onAction="#onNewCourse"/>

                            <Button fx:id="saveCourseButton"
                                    text="Guardar"
                                    styleClass="primary-button"
                                    onAction="#onSaveCourse"/>

                            <Button fx:id="deleteCourseButton"
                                    text="Eliminar"
                                    styleClass="danger-button"
                                    onAction="#onDeleteCourse"/>

                        </HBox>

                    </VBox>

                </AnchorPane>

                <!-- ===================================================== -->
                <!-- PANEL DERECHO                                         -->
                <!-- ===================================================== -->

                <AnchorPane>

                    <VBox spacing="15"
                          AnchorPane.topAnchor="0.0"
                          AnchorPane.bottomAnchor="0.0"
                          AnchorPane.leftAnchor="0.0"
                          AnchorPane.rightAnchor="0.0">

                        <Label text="Detalle de Asignatura"
                               styleClass="section-title"/>

                        <!-- FORM -->

                        <GridPane hgap="12"
                                  vgap="12">

                            <columnConstraints>

                                <ColumnConstraints
                                        minWidth="120"
                                        prefWidth="120"/>

                                <ColumnConstraints
                                        hgrow="ALWAYS"/>

                            </columnConstraints>

                            <!-- CODIGO -->

                            <Label text="Código:"
                                   GridPane.rowIndex="0"
                                   GridPane.columnIndex="0"/>

                            <TextField fx:id="codeField"
                                       GridPane.rowIndex="0"
                                       GridPane.columnIndex="1"/>

                            <!-- NOMBRE -->

                            <Label text="Nombre:"
                                   GridPane.rowIndex="1"
                                   GridPane.columnIndex="0"/>

                            <TextField fx:id="nameField"
                                       GridPane.rowIndex="1"
                                       GridPane.columnIndex="1"/>

                            <!-- CREDITOS -->

                            <Label text="Créditos:"
                                   GridPane.rowIndex="2"
                                   GridPane.columnIndex="0"/>

                            <ComboBox fx:id="creditsComboBox"
                                      prefWidth="150"
                                      GridPane.rowIndex="2"
                                      GridPane.columnIndex="1"/>

                            <!-- DESCRIPCION -->

                            <Label text="Descripción:"
                                   GridPane.rowIndex="3"
                                   GridPane.columnIndex="0"/>

                            <TextArea fx:id="descriptionArea"
                                      prefRowCount="5"
                                      wrapText="true"
                                      GridPane.rowIndex="3"
                                      GridPane.columnIndex="1"/>

                        </GridPane>

                        <!-- PREREQUISITOS -->

                        <Separator/>

                        <Label text="Prerrequisitos"
                               styleClass="section-title"/>

                        <TableView fx:id="prerequisitesTable"
                                   prefHeight="250"
                                   VBox.vgrow="ALWAYS">

                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                            </columnResizePolicy>

                            <columns>

                                <TableColumn fx:id="prerequisiteCodeColumn"
                                             text="Código"/>

                                <TableColumn fx:id="prerequisiteNameColumn"
                                             text="Asignatura"/>

                            </columns>

                        </TableView>

                        <!-- BOTONES PREREQUISITOS -->

                        <HBox spacing="10">

                            <Button fx:id="addPrerequisiteButton"
                                    text="+ Agregar"
                                    styleClass="primary-button"/>

                            <Button fx:id="removePrerequisiteButton"
                                    text="Eliminar"
                                    styleClass="danger-button"/>

                        </HBox>

                    </VBox>

                </AnchorPane>

            </SplitPane>

        </VBox>

    </center>

</BorderPane>