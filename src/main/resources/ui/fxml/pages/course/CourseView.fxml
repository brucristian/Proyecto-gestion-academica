<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15.0"
      style="-fx-background-color: #0d1b2a;"
      VBox.vgrow="ALWAYS"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.unischeduler.ui.pages.course.CourseController">

    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <!-- HEADER -->
    <VBox spacing="5.0">

        <Label text="📖 Gestión de Catálogo Académico"
               style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #ffffff;" />

        <Label text="Administración de cursos, asignaturas y prerrequisitos del plan de estudios"
               style="-fx-text-fill: #94a1b2; -fx-font-size: 13px;" />

    </VBox>

    <Separator style="-fx-opacity: 0.2; -fx-background-color: #415a77;" />

    <!-- SPLIT -->
    <SplitPane dividerPositions="0.48"
               style="-fx-background-color: #0d1b2a; -fx-box-border: transparent;"
               VBox.vgrow="ALWAYS">

        <items>

            <!-- LEFT PANEL -->
            <AnchorPane style="-fx-background-color: #152238; -fx-padding: 10;">
                <children>

                    <VBox spacing="12.0"
                          AnchorPane.topAnchor="0"
                          AnchorPane.bottomAnchor="0"
                          AnchorPane.leftAnchor="0"
                          AnchorPane.rightAnchor="0">

                        <Label text="Lista de Asignaturas"
                               style="-fx-font-weight: bold; -fx-text-fill: #ffffff; -fx-font-size: 14px;" />

                        <TextField fx:id="searchField"
                                   promptText="🔍 Buscar por código o nombre..."
                                   style="-fx-background-color: #0d1b2a; -fx-text-fill: #ffffff; -fx-border-color: #415a77;" />

                        <TableView fx:id="coursesTable"
                                   VBox.vgrow="ALWAYS"
                                   style="-fx-background-color: #0d1b2a; -fx-table-cell-border-color: #415a77;">

                            <columns>

                                <TableColumn fx:id="codeColumn"
                                             prefWidth="110.0"
                                             text="Código" />

                                <TableColumn fx:id="nameColumn"
                                             prefWidth="230.0"
                                             text="Asignatura" />

                                <TableColumn fx:id="creditsColumn"
                                             prefWidth="80.0"
                                             text="Créditos"
                                             style="-fx-alignment: CENTER;" />

                            </columns>

                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>

                        </TableView>

                        <HBox spacing="10.0">

                            <Button fx:id="newCourseButton"
                                    text="+ Nuevo"
                                    onAction="#onNewCourse"
                                    style="-fx-background-color: #2a9d8f; -fx-text-fill: #ffffff; -fx-font-weight: bold;" />

                            <Button fx:id="saveCourseButton"
                                    text="Guardar"
                                    onAction="#onSaveCourse"
                                    style="-fx-background-color: #415a77; -fx-text-fill: #ffffff; -fx-font-weight: bold;" />

                            <Button fx:id="deleteCourseButton"
                                    text="Eliminar"
                                    onAction="#onDeleteCourse"
                                    style="-fx-background-color: #e76f51; -fx-text-fill: #ffffff;" />

                        </HBox>

                    </VBox>

                </children>
            </AnchorPane>

            <!-- RIGHT PANEL -->
            <AnchorPane style="-fx-background-color: #152238; -fx-padding: 10;">
                <children>

                    <VBox spacing="15.0"
                          AnchorPane.topAnchor="0"
                          AnchorPane.bottomAnchor="0"
                          AnchorPane.leftAnchor="0"
                          AnchorPane.rightAnchor="0">

                        <Label text="Detalle de Asignatura"
                               style="-fx-font-weight: bold; -fx-text-fill: #ffffff; -fx-font-size: 14px;" />

                        <!-- FORM -->
                        <GridPane hgap="12.0" vgap="12.0">

                            <columnConstraints>
                                <ColumnConstraints minWidth="100.0" prefWidth="110.0" />
                                <ColumnConstraints hgrow="ALWAYS" />
                            </columnConstraints>

                            <Label text="Código:"
                                   style="-fx-text-fill: #94a1b2; -fx-font-weight: bold;"
                                   GridPane.columnIndex="0"
                                   GridPane.rowIndex="0" />

                            <TextField fx:id="codeField"
                                       style="-fx-background-color: #0d1b2a; -fx-text-fill: #ffffff; -fx-border-color: #415a77;"
                                       GridPane.columnIndex="1"
                                       GridPane.rowIndex="0" />

                            <Label text="Nombre:"
                                   style="-fx-text-fill: #94a1b2; -fx-font-weight: bold;"
                                   GridPane.columnIndex="0"
                                   GridPane.rowIndex="1" />

                            <TextField fx:id="nameField"
                                       style="-fx-background-color: #0d1b2a; -fx-text-fill: #ffffff; -fx-border-color: #415a77;"
                                       GridPane.columnIndex="1"
                                       GridPane.rowIndex="1" />

                            <Label text="Créditos:"
                                   style="-fx-text-fill: #94a1b2; -fx-font-weight: bold;"
                                   GridPane.columnIndex="0"
                                   GridPane.rowIndex="2" />

                            <ComboBox fx:id="creditsComboBox"
                                      style="-fx-background-color: #0d1b2a; -fx-text-fill: #ffffff; -fx-border-color: #415a77;"
                                      GridPane.columnIndex="1"
                                      GridPane.rowIndex="2" />

                            <Label text="Descripción:"
                                   style="-fx-text-fill: #94a1b2; -fx-font-weight: bold;"
                                   GridPane.columnIndex="0"
                                   GridPane.rowIndex="3" />

                            <TextArea fx:id="descriptionArea"
                                      prefRowCount="4"
                                      wrapText="true"
                                      style="-fx-control-inner-background: #0d1b2a; -fx-text-fill: #ffffff; -fx-border-color: #415a77;"
                                      GridPane.columnIndex="1"
                                      GridPane.rowIndex="3" />

                        </GridPane>

                        <Separator style="-fx-opacity: 0.2; -fx-background-color: #415a77;" />

                        <!-- PREREQUISITES -->
                        <Label text="Prerrequisitos Requeridos"
                               style="-fx-font-weight: bold; -fx-text-fill: #ffffff; -fx-font-size: 14px;" />

                        <TableView fx:id="prerequisitesTable"
                                   prefHeight="200.0"
                                   VBox.vgrow="ALWAYS"
                                   style="-fx-background-color: #0d1b2a;">

                            <columns>

                                <TableColumn fx:id="prerequisiteCodeColumn"
                                             prefWidth="120.0"
                                             text="Código" />

                                <TableColumn fx:id="prerequisiteNameColumn"
                                             prefWidth="280.0"
                                             text="Asignatura" />

                            </columns>

                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>

                        </TableView>

                        <HBox spacing="10.0">

                            <Button fx:id="addPrerequisiteButton"
                                    text="➕ Agregar Prerrequisito"
                                    onAction="#onAddPrerequisite"
                                    style="-fx-background-color: #2a9d8f; -fx-text-fill: #ffffff; -fx-cursor: hand;" />

                            <Button fx:id="removePrerequisiteButton"
                                    text="🗑 Quitar"
                                    onAction="#onRemovePrerequisite"
                                    style="-fx-background-color: #e76f51; -fx-text-fill: #ffffff; -fx-cursor: hand;" />

                        </HBox>

                    </VBox>

                </children>
            </AnchorPane>

        </items>

    </SplitPane>

</VBox>