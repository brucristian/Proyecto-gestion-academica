<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="700.0" prefWidth="1100.0" spacing="15.0" style="-fx-padding: 20; -fx-background-color: -fx-bg-dark-primary;" stylesheets="@/css/global.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <Label styleClass="label-title" text="Proceso de Matrícula" />

        <HBox alignment="CENTER" spacing="50.0" styleClass="stepper-container" stylesheets="@/css/enrollment.css">
            <children>
                <HBox alignment="CENTER" spacing="10.0">
                    <children>
                        <Label styleClass="step-active" text="1" />
                        <Label style="-fx-font-weight: bold; -fx-text-fill: -fx-text-main;" text="Selección de Grupos" />
                    </children>
                </HBox>
                <HBox alignment="CENTER" spacing="10.0" opacity="0.5">
                    <children>
                        <Label styleClass="step-inactive" text="2" />
                        <Label text="Validación" />
                    </children>
                </HBox>
                <HBox alignment="CENTER" spacing="10.0" opacity="0.5">
                    <children>
                        <Label styleClass="step-inactive" text="3" />
                        <Label text="Confirmación" />
                    </children>
                </HBox>
            </children>
        </HBox>

        <HBox spacing="20.0" VBox.vgrow="ALWAYS">
            <children>

                <VBox spacing="10.0" HBox.hgrow="ALWAYS" prefWidth="600.0">
                    <children>
                        <Label style="-fx-font-weight: bold;" text="Oferta Académica (Grupos Disponibles)" />

                        <HBox spacing="10.0">
                            <children>
                                <Label text="Filtrar por:" alignment="CENTER" style="-fx-padding: 5 0 0 0;" />
                                <ComboBox promptText="Todas las asignaturas" prefWidth="180.0" />
                                <TextField promptText="Buscar asignatura..." HBox.hgrow="ALWAYS" />
                                <Button text="🔍" styleClass="button" style="-fx-background-color: -fx-bg-dark-tertiary;" />
                            </children>
                        </HBox>

                        <TableView VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn prefWidth="40.0" style="-fx-alignment: CENTER;" /> <TableColumn prefWidth="70.0" text="Código" />
                                <TableColumn prefWidth="180.0" text="Asignatura" />
                                <TableColumn prefWidth="60.0" text="Grupo" style="-fx-alignment: CENTER;" />
                                <TableColumn prefWidth="120.0" text="Docente" />
                                <TableColumn prefWidth="100.0" text="Horario" />
                                <TableColumn prefWidth="70.0" text="Cupos" style="-fx-alignment: CENTER;" />
                            </columns>
                        </TableView>
                    </children>
                </VBox>

                <VBox spacing="10.0" prefWidth="450.0">
                    <children>
                        <Label style="-fx-font-weight: bold;" text="Horario Provisional (Seleccionados)" />

                        <TableView prefHeight="250.0">
                            <columns>
                                <TableColumn prefWidth="150.0" text="Asignatura" />
                                <TableColumn prefWidth="60.0" text="Grupo" style="-fx-alignment: CENTER;" />
                                <TableColumn prefWidth="140.0" text="Horario" />
                                <TableColumn prefWidth="60.0" text="Acción" style="-fx-alignment: CENTER;" /> </columns>
                        </TableView>

                        <VBox spacing="5.0" styleClass="warning-box" stylesheets="@/css/enrollment.css">
                            <children>
                                <Label style="-fx-font-weight: bold; -fx-text-fill: -fx-accent-red;" text="⚠️ Validaciones (Advertencias)" />
                                <Label styleClass="warning-text" text="• Cruce de horario entre Programación I (G01) y Cálculo II (G01) los días Lunes." wrapText="true" />
                                <Label styleClass="warning-text" text="• Prerrequisito pendiente para FIS101: Física Mecánica." wrapText="true" />
                            </children>
                        </VBox>

                        <HBox alignment="CENTER_LEFT" style="-fx-padding: 10 0 0 0;">
                            <Label style="-fx-font-weight: bold; -fx-font-size: 14px;" text="Total Créditos: 6" />
                        </HBox>
                    </children>
                </VBox>
            </children>
        </HBox>

        <HBox alignment="CENTER_RIGHT" spacing="15.0">
            <children>
                <Button text="Limpiar Selección" style="-fx-background-color: transparent; -fx-border-color: -fx-bg-dark-tertiary; -fx-text-fill: -fx-text-muted;" styleClass="button" />
                <Button text="Siguiente: Validar ➔">
                    <styleClass>
                        <String fx:value="button" />
                        <String fx:value="btn-success" />
                    </styleClass>
                </Button>
            </children>
        </HBox>
    </children>
</VBox>