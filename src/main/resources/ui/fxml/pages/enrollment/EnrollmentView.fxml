<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.TableView?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.unischeduler.ui.pages.enrollment.EnrollmentController"
            style="-fx-background-color: #0d1b2a;">

    <center>
        <VBox spacing="20" style="-fx-padding: 20;">

            <HBox alignment="CENTER" spacing="80">
                <Label text="1. Selección de Grupos" style="-fx-text-fill: #2a9d8f; -fx-font-weight: bold;"/>
                <Label text="2. Validación" style="-fx-text-fill: #94a1b2;"/>
                <Label text="3. Confirmación" style="-fx-text-fill: #94a1b2;"/>
            </HBox>

            <Separator style="-fx-background-color: #415a77;"/>

            <HBox spacing="20" VBox.vgrow="ALWAYS">

                <VBox spacing="10" HBox.hgrow="ALWAYS">
                    <Label text="Oferta Académica (Grupos Disponibles)" style="-fx-text-fill: white; -fx-font-weight: bold;"/>

                    <TableView fx:id="availableGroupsTable" VBox.vgrow="ALWAYS"
                               style="-fx-background-color: #152238; -fx-table-cell-border-color: #2b3a4a; -fx-border-color: #415a77; -fx-border-radius: 6;">
                        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                        <columns>
                            <TableColumn fx:id="selectedColumn" text="" prefWidth="40"/>
                            <TableColumn fx:id="codeColumn" text="Cód." prefWidth="50"/>
                            <TableColumn fx:id="courseColumn" text="Asignatura" prefWidth="150"/>
                            <TableColumn fx:id="groupColumn" text="Grp." prefWidth="50"/>
                            <TableColumn fx:id="teacherColumn" text="Docente" prefWidth="120"/>
                            <TableColumn fx:id="scheduleColumn" text="Horario" prefWidth="160"/>
                            <TableColumn fx:id="capacityColumn" text="Cupos" prefWidth="60"/>
                        </columns>
                    </TableView>

                    <HBox spacing="10">
                        <TextField fx:id="searchField" promptText="Buscar asignatura..." HBox.hgrow="ALWAYS"
                                   style="-fx-background-color: #152238; -fx-text-fill: white; -fx-prompt-text-fill: #778da9; -fx-border-color: #415a77; -fx-border-radius: 4;"/>
                        <Button text="🔍" style="-fx-background-color: #2a9d8f; -fx-text-fill: white; -fx-cursor: hand;"/>
                    </HBox>
                </VBox>

                <VBox spacing="15" prefWidth="420">
                    <Label text="Horario Provisional (Seleccionados)" style="-fx-text-fill: white; -fx-font-weight: bold;"/>

                    <TableView fx:id="selectedGroupsTable" prefHeight="250"
                               style="-fx-background-color: #152238; -fx-table-cell-border-color: #2b3a4a; -fx-border-color: #415a77; -fx-border-radius: 6;">
                        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                        <columns>
                            <TableColumn fx:id="selectedCourseColumn" text="Asignatura" prefWidth="130"/>
                            <TableColumn fx:id="selectedGroupColumn" text="Grp" prefWidth="50"/>
                            <TableColumn fx:id="selectedScheduleColumn" text="Horario" prefWidth="130"/>
                            <TableColumn fx:id="removeColumn" text="Acción" prefWidth="70"/>
                        </columns>
                    </TableView>

                    <VBox spacing="8">
                        <Label text="Validaciones (Advertencias)" style="-fx-text-fill: #e76f51; -fx-font-weight: bold;"/>
                        <ListView fx:id="validationListView" prefHeight="120"
                                  style="-fx-background-color: #152238; -fx-border-color: #e76f51; -fx-border-radius: 4; -fx-text-fill: white;"/>
                    </VBox>

                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="Total Créditos:" style="-fx-text-fill: white;"/>
                        <Label fx:id="totalCreditsLabel" text="0" style="-fx-text-fill: #2a9d8f; -fx-font-weight: bold; -fx-font-size: 16px;"/>
                    </HBox>

                    <HBox spacing="10">
                        <Button fx:id="clearSelectionButton" text="Limpiar" HBox.hgrow="ALWAYS" maxWidth="Infinity" onAction="#onClearSelection"
                                style="-fx-background-color: #415a77; -fx-text-fill: white; -fx-cursor: hand;"/>
                        <Button fx:id="nextButton" text="Confirmar" HBox.hgrow="ALWAYS" maxWidth="Infinity" onAction="#onSaveEnrollment"
                                style="-fx-background-color: #2a9d8f; -fx-text-fill: white; -fx-cursor: hand; -fx-font-weight: bold;"/>
                    </HBox>
                </VBox>
            </HBox>
        </VBox>
    </center>
</BorderPane>