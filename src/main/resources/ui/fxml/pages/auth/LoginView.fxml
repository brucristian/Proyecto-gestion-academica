<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<HBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="500.0" prefWidth="800.0" stylesheets="@/css/global.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.unischeduler.ui.pages.auth.LoginController">
    <children>
        <VBox alignment="CENTER" prefWidth="350.0" spacing="15.0" styleClass="login-side-pane" stylesheets="@/css/login.css" HBox.hgrow="ALWAYS">
            <children>
                <Pane styleClass="icon-login, login-logo-large" />

                <VBox alignment="CENTER" spacing="0.0">
                    <children>
                        <Label style="-fx-font-size: 26px; -fx-font-weight: bold;" text="Sistema de" textAlignment="CENTER" wrapText="true" />
                        <Label style="-fx-font-size: 26px; -fx-font-weight: bold;" text="Matrícula" textAlignment="CENTER" wrapText="true" />
                        <Label style="-fx-font-size: 26px; -fx-font-weight: bold;" text="Académica" textAlignment="CENTER" wrapText="true" />
                    </children>
                </VBox>

                <Label opacity="0.7" style="-fx-padding: 10 0 0 0;" text="Tu camino académico, conectado." textAlignment="CENTER" wrapText="true" />
            </children>
        </VBox>

        <VBox alignment="CENTER" prefWidth="450.0" styleClass="login-container" stylesheets="@/css/login.css" HBox.hgrow="ALWAYS">
            <children>
                <VBox maxWidth="340.0" spacing="15.0" styleClass="login-card">
                    <children>
                        <VBox alignment="CENTER" spacing="5.0">
                            <children>
                                <Label styleClass="label-title" text="Iniciar Sesión" />
                                <Label styleClass="label-subtitle" text="Ingrese sus credenciales para continuar" />
                            </children>
                        </VBox>

                        <VBox spacing="5.0">
                            <children>
                                <Label text="Usuario (código o email)" />
                                <TextField fx:id="usernameField" promptText="ej. 20211234 o email@universidad.edu" />
                            </children>
                        </VBox>

                        <VBox spacing="5.0">
                            <children>
                                <Label text="Contraseña" />
                                <PasswordField fx:id="passwordField" promptText="••••••••" />
                            </children>
                        </VBox>

                        <HBox alignment="CENTER_LEFT">
                            <children>
                                <CheckBox mnemonicParsing="false" text="Recordar mis credenciales" />
                                <HBox alignment="CENTER_RIGHT" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Hyperlink text="¿Olvidó su contraseña?" />
                                    </children>
                                </HBox>
                            </children>
                        </HBox>

                        <Label fx:id="messageLabel" style="-fx-text-fill: -fx-accent-red;" wrapText="true" />

                        <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#login" text="Ingresar">
                            <styleClass>
                                <String fx:value="button" />
                                <String fx:value="btn-primary" />
                            </styleClass>
                        </Button>

                        <HBox alignment="CENTER" style="-fx-padding: 10 0 0 0;">
                            <children>
                                <Label opacity="0.6" text="¿No tiene una cuenta? Contacte al administrador." />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</HBox>