<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.VBox?>

<VBox prefWidth="220.0" styleClass="sidebar" stylesheets="@/css/dasboard.css"
      spacing="5.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.unischeduler.ui.components.sidebar.StudentSidebarController">
    <children>
        <Button fx:id="btnHome" maxWidth="Infinity" mnemonicParsing="false" onAction="#goToDashboard" styleClass="sidebar-btn-active" text=" Dashboard" />
        <Button fx:id="btnEnrollment" maxWidth="Infinity" mnemonicParsing="false" onAction="#goToEnrollment" styleClass="sidebar-btn" text=" Mi Matrícula" />
        <Button fx:id="btnHistory" maxWidth="Infinity" mnemonicParsing="false" onAction="#goToAcademicHistory" styleClass="sidebar-btn" text="📊 Historial Académico" />
        <Button fx:id="btnSchedule" maxWidth="Infinity" mnemonicParsing="false" onAction="#goToProvisionalSchedule" styleClass="sidebar-btn" text=" Horario Provisional" />
        <Button fx:id="btnProfile" maxWidth="Infinity" mnemonicParsing="false" onAction="#goToProfile" styleClass="sidebar-btn" text="Perfil" />

        <VBox alignment="BOTTOM_LEFT" VBox.vgrow="ALWAYS">
            <children>
                <Button fx:id="btnLogout" maxWidth="Infinity" mnemonicParsing="false" onAction="#goToLogin">
                    <styleClass>
                        <String fx:value="sidebar-btn" />
                    </styleClass>
                    <text>🚪 Cerrar Sesión</text>
                </Button>
            </children>
        </VBox>
    </children>
</VBox>